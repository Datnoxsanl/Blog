<form  class="mt-4" name="container-form" method="post" action="/courses/handel-form-actions">
  <h1>Khóa học của tôi</h1>
  <a href="/me/trash/courses">Xem khóa học đã xóa ({{deletedCount}})</a>
  <div class="mt-4 d-flex align-items-center gap-2">

    <div class="form-check">
      <input
        class="form-check-input"
        type="checkbox"
        value=""
        id="checkbox-all"
      />
      <label class="form-check-label" for="checkbox-all">
        Chọn tất cả
      </label>
    </div>

    <select
      class="form-select form-select-sm mb-3 checkbox-select-all-options"
      aria-label="Large select example"
      name="action"
      required
    >
      <option value=""> Chọn hành động</option>
      <option value="delete">Xóa</option>
    </select>

    <button class="btn btn-primary btn-sm btn-check-all disabled">Áp dụng</button>
  </div>

</form>
<table class="table">
  <thead>
    <tr>
      <th scope="col">#</th>
      <th scope="col">Tên khóa học</th>
      <th scope="col">Thời gian xóa</th>
      <th scope="col" colspan="2">Level</th>
    </tr>
  </thead>
  <tbody>
    {{#each courses}}
      <tr>
        <td>
          <div class="form-check">
            <input
              class="form-check-input checkbox-course"
              type="checkbox"
              name="coursesIds[]"
              value="{{this._id}}"
            />
          </div>
        </td>
        <th scope="row">{{sum @index 1}}</th>
        <td>{{this.name}}</td>
        <td>{{this.deletedAt}}</td>
        <td>{{this.level}}</td>
        <td>
          <a href="/courses/{{this._id}}/edit" class="btn btn-link">Sửa</a>
          <a
            href="/courses/{{this._id}}/delete"
            class="btn btn-link"
            data-bs-toggle="modal"
            data-bs-target="#delete-course-modal"
            data-id="{{this._id}}"
          >Xóa</a>
        </td>

      </tr>
    {{else}}
      <tr>
        <td colspan="5" class="text-center">Không có khóa học nào
          <a href="/courses/create">Tạo khóa học mới</a>
        </td>
      </tr>
    {{/each}}

  </tbody>
</table>

<!-- confirm delete Modal -->
<div
  class="modal fade"
  id="delete-course-modal"
  tabindex="-1"
  aria-labelledby="exampleModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">Xác nhận xóa khóa
          học</h1>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
          aria-label="Close"
        ></button>
      </div>
      <div class="modal-body">
        Bạn có chắc chắn muốn xóa khóa học này không?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-danger" id="btn-delete-course">Xóa
          bỏ</button>
        <button
          type="button"
          class="btn btn-primary"
          data-bs-dismiss="modal"
        >Hủy</button>
      </div>
    </div>
  </div>
</div>

{{! Delete hidden form }}
<form name="delete-course-form" method="POST"></form>

<script>
  const exampleModal = document.getElementById('delete-course-modal');
  const btnDelete = document.getElementById('btn-delete-course');
  const deleteCourseForm = document.forms['delete-course-form'];

  const checkboxAll = document.getElementById('checkbox-all');
  const courseCheckboxes = document.querySelectorAll('input[name="coursesIds[]"]');
  const checkAllSubmitBtn = document.querySelector('.btn-check-all');
  const containerForm = document.forms['container-form'];

  let courseId = null;

  // ===== Modal delete 1 course =====
  if (exampleModal) {
    exampleModal.addEventListener('show.bs.modal', function (event) {
      const button = event.relatedTarget;
      courseId = button.getAttribute('data-id');
    });
  }

  if (btnDelete) {
    btnDelete.onclick = function () {
      deleteCourseForm.action = '/courses/' + courseId + '?_method=DELETE';
      deleteCourseForm.submit();
    };
  }

  // ===== Checkbox "Chọn tất cả" =====
  if (checkboxAll) {
    checkboxAll.addEventListener('change', function () {
      const isChecked = this.checked;

      courseCheckboxes.forEach(function (checkbox) {
        checkbox.checked = isChecked;
      });

      renderCheckAllSubmitBtn();
    });
  }

  // ===== Khi từng checkbox thay đổi =====
  courseCheckboxes.forEach(function (checkbox) {
    checkbox.addEventListener('change', function () {

      const checkedCount = document.querySelectorAll('input[name="coursesIds[]"]:checked').length;
      const totalCount = courseCheckboxes.length;

      checkboxAll.checked = checkedCount === totalCount;

      renderCheckAllSubmitBtn();
    });
  });

  // ===== Click nút Áp dụng =====
  if (checkAllSubmitBtn) {
    checkAllSubmitBtn.addEventListener('click', function (e) {
      if (this.classList.contains('disabled')) {
        e.preventDefault();
        return;
      }

      containerForm.submit();
    });
  }

  // ===== Bật / tắt nút Áp dụng =====
  function renderCheckAllSubmitBtn() {
    const checkedCount = document.querySelectorAll('input[name="coursesIds[]"]:checked').length;

    if (checkedCount > 0) {
      checkAllSubmitBtn.classList.remove('disabled');
    } else {
      checkAllSubmitBtn.classList.add('disabled');
    }
  }
</script>